r2_hol = 1 - np.sum((observed_effects - pred_hol)**2) / np.sum((observed_effects - observed_effects.mean())**2)
r2_resp = 1 - np.sum((observed_effects - pred_resp)**2) / np.sum((observed_effects - observed_effects.mean())**2)

